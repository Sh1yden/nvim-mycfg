diff -ruN '--exclude=.git' nvim-mycfg-orig4/lua/plugins/tiny-inline-diagnostic.lua nvim-mycfg/lua/plugins/tiny-inline-diagnostic.lua
--- nvim-mycfg-orig4/lua/plugins/tiny-inline-diagnostic.lua	1970-01-01 00:00:00.000000000 +0000
+++ nvim-mycfg/lua/plugins/tiny-inline-diagnostic.lua	2026-07-24 20:55:34.302679834 +0000
@@ -0,0 +1,17 @@
+return {
+  {
+    "rachartier/tiny-inline-diagnostic.nvim",
+    event = "LspAttach",
+    config = function()
+      require("tiny-inline-diagnostic").setup({
+        preset = "modern",
+        options = {
+          show_source = true,
+        },
+      })
+      -- Свой рендер диагностик заменяет стандартный virtual_text от Neovim,
+      -- иначе будет дублирование одной и той же ошибки дважды
+      vim.diagnostic.config({ virtual_text = false })
+    end,
+  },
+}
