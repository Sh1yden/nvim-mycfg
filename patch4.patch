diff -ruN '--exclude=.git' nvim-mycfg-orig4/lua/plugins/smear-cursor.lua nvim-mycfg/lua/plugins/smear-cursor.lua
--- nvim-mycfg-orig4/lua/plugins/smear-cursor.lua	1970-01-01 00:00:00.000000000 +0000
+++ nvim-mycfg/lua/plugins/smear-cursor.lua	2026-07-24 20:55:34.296887118 +0000
@@ -0,0 +1,15 @@
+return {
+  {
+    "sphamba/smear-cursor.nvim",
+    -- Только в терминале — в Neovide курсор уже анимируется нативно
+    -- (см. neovide.lua), включать оба одновременно смысла нет.
+    cond = not vim.g.neovide,
+    event = "VeryLazy",
+    opts = {
+      cursor_color = "#c8c093",
+      stiffness = 0.6,
+      trailing_stiffness = 0.3,
+      distance_stop_animating = 0.5,
+    },
+  },
+}
